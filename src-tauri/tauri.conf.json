{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Number Goes Up",
  "version": "0.1.0",
  "identifier": "com.clocktower.numbergoesup",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "NUMBER GOES UP",
        "width": 480,
        "height": 820,
        "minWidth": 360,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Game",
    "shortDescription": "There is a number. It goes up.",
    "longDescription": "A $0.99 idle/incremental game with no story, no ending, and no payoff. The number goes up. That's it. That's the game.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
